# ========== LLM（DeepSeek）==========
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=deepseek-chat

# 可选：API 请求超时（秒），默认 30
LLM_TIMEOUT=30

# ========== Playwright 浏览器（v2.0 内嵌实现，不走 MCP）==========
# 不需要 MCP_* 配置；浏览器由 app.core.browser.PlaywrightBrowser 直接拉起

# ========== PostgreSQL（docker-compose.yml 提供，端口 10010）==========
# 起停：docker compose up -d postgres / docker compose down
POSTGRES_HOST=localhost
POSTGRES_PORT=10010
POSTGRES_DB=open_data_meta_guard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# ========== 数据下载与质量评估 ==========
DOWNLOAD_DIR=./data
DOWNLOAD_TIMEOUT=60
DOWNLOAD_MAX_FILE_SIZE_MB=500

QUALITY_SAMPLE_SIZE=100000
QUALITY_MINIMAL_MODE=true
