# ============================================================
#  open-data-meta-guard v2.0 根目录 .gitignore
#  前端 (web/) + 后端 (backend/) + 文档 (docs/) 统一规则
# ============================================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
*.whl
.eggs/
build/
dist/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# ---------- Node / Frontend ----------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Build output
dist/
dist-ssr/
*.local

# Vite / Vue
.vite/
.cache/

# Coverage
coverage/
.nyc_output/

# ---------- Logs & runtime ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- Environment / secrets ----------
.env
.env.local
.env.*.local
!.env.example

# ---------- IDE / Editor ----------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Misc ----------
.playwright-cli/
.open_data_meta_guard*/
data/uploads/*
!data/uploads/.gitkeep
data/raw/*
!data/raw/.gitkeep
backend/data
docs